    if(mood)h+='<div class="comic-caption comic-caption-mood">'+mood+'</div>';
    h+='</div>';
    h+='</div>'; // /strip
    h+='</div>'; // /scene
  });
  h+='</div>';

  h+='<button class="start-btn" onclick="resetGame()">학기 처음부터</button>';
  h+='</div></div>';
  container.innerHTML=h;
}

