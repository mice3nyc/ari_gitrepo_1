    h+='<div class="comic-strip">';
    // 4/30 세션260 — 코믹스트립: 각 컷 = panel(이미지 + 캡션)
    for(var c=1;c<=5;c++){
      var src=getCutImageFor(r.scenarioId, r.leaf, c);
