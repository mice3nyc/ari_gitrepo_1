  h+='<button class="start-btn secondary" onclick="resetGame()">학기 처음부터</button>';
  h+='</div></div>';
  container.innerHTML=h;
}

// v0.5: 학기 종합 리포트 (5 시나리오 다 끝났을 때)
// v0.5 Phase 8.13 — 결과 리포트 헬퍼

// hist 데이터(scenarioId, leaf)로 카툰 이미지 경로 산출. gameState 무관.
function getCutImageFor(scenarioId, leaf, cutNum){
  var n=({'selfintro':'01','groupwork':'02','eorinwangja':'03','career':'04','studyplan':'05'})[scenarioId]||'01';
  var base='../images/s'+n;
  var t1=leaf?leaf.charAt(0):null;
  var t2=leaf?leaf.substr(0,2):null;
  var rv=leaf?leaf.substr(2):null;
  if(cutNum===1)return base+'_c1.webp';
  if(cutNum===2)return t1?base+'_c2_'+t1+'.webp':null;
  if(cutNum===3)return t2?base+'_c3_'+t2+'.webp':null;
  if(cutNum===4)return t2?base+'_c4_'+t2+'.webp':null;
  if(cutNum===5)return rv?base+'_c5_'+rv+'.webp':null;
  return null;
}

// 4/30 세션260 — 컷별 캡션 (코믹스트립용). hist의 r.leaf 기반, gameState 무관
// 메시지 중심 — lesson 필드 우선. 위임판단력·도메인지식 두 축 임팩트.
// 시나리오에 lesson이 없으면 label/desc/summary로 fallback (다른 시나리오 호환)
function getCutCaptionFor(scenarioId, leaf, cutNum){
  var sc=SCENARIOS[scenarioId]; if(!sc) return '';
  var t1=leaf?leaf.charAt(0):null;
  var t2=leaf?leaf.substr(0,2):null;
  var rv=leaf?leaf.substr(2):null;
  function _first(text){ if(!text) return ''; var m=text.match(/^[^.!?]+[.!?]/); return m?m[0].trim():text; }
  function _esc(s){ return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  if(cutNum===1){
    var intro=_first(sc.situation && sc.situation.text);
    return '<b>'+_esc(sc.title||'')+'</b>'+_esc(intro);
  }
  if(cutNum===2 && t1){
    var t1arr=sc.tier1||[];
    for(var i=0;i<t1arr.length;i++){
      if(t1arr[i].id===t1){
        if(t1arr[i].lesson) return '<b>'+_esc(t1arr[i].lesson)+'</b>';
        return '<b>'+_esc(t1arr[i].label||'')+'</b>'+_esc(t1arr[i].desc||'');
      }
    }
    return '';
  }
  if(cutNum===3 && t2){
    var t2arr=(sc.tier2||{})[t1]||[];
    for(var j=0;j<t2arr.length;j++){
      if(t2arr[j].id===t2){
        if(t2arr[j].lesson) return '<b>'+_esc(t2arr[j].lesson)+'</b>';
        return '<b>'+_esc(t2arr[j].label||'')+'</b>';
      }
    }
    return '';
  }
  if(cutNum===4 && t2){
    var rs=(sc.results||{})[t2];
    if(!rs) return '';
    var summary=rs.summary||'';
    if(rs.lesson) return (summary?'<b>'+_esc(summary)+'</b>':'')+_esc(rs.lesson);
    var firstLine=_first(rs.text||'');
    return (summary?'<b>'+_esc(summary)+'</b>':'')+_esc(firstLine);
  }
  if(cutNum===5 && rv){
    var rvArr=sc.reviews||[];
    var rvObj=null;
    for(var k=0;k<rvArr.length;k++){ if(rvArr[k].id===rv){ rvObj=rvArr[k]; break; } }
    var supp=(sc.reviewSupplements||{})[leaf];
    if(rvObj && rvObj.lesson) return '<b>'+_esc(rvObj.lesson)+'</b>'+(supp?_esc(supp):'');
    if(supp) return (rvObj?'<b>'+_esc(rvObj.label||'')+'</b>':'')+_esc(supp);
    return rvObj ? '<b>'+_esc(rvObj.label||'')+'</b>'+_esc(rvObj.desc||'') : '';
  }
  return '';
}

// 위/도 4유형 분류 — 'pp'/'pn'/'np'/'nn'/'mid' (DECISIONS §10.13)
function getCompetencyType(d, k){
  var z=(typeof CONFIG.resultMidZone==='number')?CONFIG.resultMidZone:2;
  if(Math.abs(d)<=z && Math.abs(k)<=z)return 'mid';
  return (d>0?'p':'n')+(k>0?'p':'n');
}

