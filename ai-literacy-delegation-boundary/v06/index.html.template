// 선택 버튼에 표시할 비용 미터 HTML — 시간/에너지 숫자+바
// v0.5 Phase 8 — 잔여자원 부족 판정 (DECISIONS §9.2)
function canAffordCost(cost){
  if(!gameState.resources)return true;
  return cost.time<=gameState.resources.time.current && cost.energy<=gameState.resources.energy.current;
}
// v0.5 Phase 8.9 + 비용 표시 디자인 (DECISIONS §10.6 4/30 세션257)
// raw cost (빨강) + 위/도 효과 (초록 할인 / 빨강 페널티 / 회색 점선 0) 4박스 그리드
function buildEffectCell(label,value){
  var cls='cost-box-effect',text;
  if(value===0){cls+=' zero';text='0';}
  else if(value>0){text='-'+value;}
  else {cls+=' penalty';text='+'+(-value);}
  return '<div class="cost-cell"><div class="cost-cell-label">'+label+'</div><div class="'+cls+'">'+text+'</div></div>';
}
function buildCostGroup(costLabel,rawCost,effectLabel,value){
  return '<div class="cost-group">'+
    '<div class="cost-cell"><div class="cost-cell-label">'+costLabel+'</div><div class="cost-box-main">'+rawCost+'</div></div>'+
    buildEffectCell(effectLabel,value)+
  '</div>';
}
function buildCostHTML(cost){
  var d=cost._discount||{dlgEffect:0,knlEffect:0,rawTime:cost.time,rawEnergy:cost.energy};
  // 효과 박스 값은 배율 적용된 효과량 (위 +3 × 배율 3 → -9). 머리로 raw - effect 합산.
  return '<div class="choice-cost">'+
    buildCostGroup('시간 비용',d.rawTime,'위임판단력',d.dlgEffect)+
    buildCostGroup('에너지 비용',d.rawEnergy,'도메인지식',d.knlEffect)+
  '</div>';
}

// 컷 2: 1차 선택 (A·B·C)
function goCut2(){
  var sc=getScenario();
  var c1=currentRow.querySelector('[data-cut="1"] .advance-wrap');if(c1)c1.style.display='none';
  setPanelImage(2,'1차 선택');
  var panel=activatePanel(2);
  var area=document.createElement('div');area.className='choices-area';area.id='tier1-choices';
  area.innerHTML='<div class="choices-q">어떻게 할까?</div>';
  panel.querySelector('.panel-body').innerHTML='';
  panel.querySelector('.panel-body').appendChild(area);
  // 각 t1 비용 사전 계산 + 정규화 max
  var costs=sc.tier1.map(function(c){return getTier1Cost(c.id);});
  var maxT=Math.max(1,Math.max.apply(null,costs.map(function(c){return c.time;})));
  var maxE=Math.max(1,Math.max.apply(null,costs.map(function(c){return c.energy;})));
  sc.tier1.forEach(function(c,i){
    var card=document.createElement('div');
    var afford=canAffordCost(costs[i]);
    card.className='choice-card'+(afford?'':' disabled');
    if(afford)card.onclick=function(){onTier1(c.id);};
    var costHTML=buildCostHTML(costs[i],maxT,maxE);
    var tag=afford?'':'<span class="insufficient-tag">자원 부족</span>';
    card.innerHTML='<div class="choice-num">'+c.id+'</div><div class="choice-body"><div class="choice-text">'+c.label+tag+'</div><div class="choice-desc">'+c.desc+'</div>'+costHTML+'</div>';
    area.appendChild(card);
    setTimeout(function(){card.classList.add('visible');},i*120+150);
  });
  updateStats();
}

// 컷 3: 2차 선택 (선택된 1차의 3개)
function goCut3(){
  var sc=getScenario(),t1=gameState.selectedTier1;
  var c2body=currentRow.querySelector('[data-cut="2"] .panel-body');
  var t1obj=sc.tier1.find(function(x){return x.id===t1;});
  c2body.innerHTML='<div class="chosen-summary"><div class="chosen-label">1차 선택</div><div class="chosen-title">'+t1+'. '+t1obj.label+'</div><div class="chosen-way">'+t1obj.desc+'</div></div>';
  setPanelImage(2,'1차 선택');
  setPanelImage(3,'2차 선택');
  var panel=activatePanel(3);
  var area=document.createElement('div');area.className='choices-area';area.id='tier2-choices';
  area.innerHTML='<div class="choices-q">더 자세히 — 어떻게 할까?</div>';
  panel.querySelector('.panel-body').innerHTML='';
  panel.querySelector('.panel-body').appendChild(area);
  var t2list=sc.tier2[t1];
  // 각 t2 추가 비용 사전 계산
  var costs=t2list.map(function(c){return getTier2Cost(c.id);});
  var maxT=Math.max(1,Math.max.apply(null,costs.map(function(c){return c.time;})));
  var maxE=Math.max(1,Math.max.apply(null,costs.map(function(c){return c.energy;})));
  t2list.forEach(function(c,i){
    var card=document.createElement('div');
    var afford=canAffordCost(costs[i]);
    card.className='choice-card'+(afford?'':' disabled');
    if(afford)card.onclick=function(){onTier2(c.id);};
    var costHTML=buildCostHTML(costs[i],maxT,maxE);
    var tag=afford?'':'<span class="insufficient-tag">자원 부족</span>';
    card.innerHTML='<div class="choice-num">'+(i+1)+'</div><div class="choice-body"><div class="choice-text">'+c.label+tag+'</div>'+costHTML+'</div>';
    area.appendChild(card);
    setTimeout(function(){card.classList.add('visible');},i*120+150);
  });
  updateStats();
}

// 컷 4: 결과 (raw 결과물)
function goCut4(){
  var sc=getScenario(),t2=gameState.selectedTier2;
  var t2obj=sc.tier2[gameState.selectedTier1].find(function(x){return x.id===t2;});
  // 컷3 요약
  var c3body=currentRow.querySelector('[data-cut="3"] .panel-body');
  c3body.innerHTML='<div class="chosen-summary"><div class="chosen-label">2차 선택</div><div class="chosen-title">'+t2+'. '+t2obj.label+'</div><div class="chosen-way">위임 깊이: '+t2obj.delegation+'</div></div>';
  setPanelImage(3,'2차 선택');
  setPanelImage(4,'결과');
  var panel=activatePanel(4);
  var result=sc.results[t2];
  panel.querySelector('.panel-body').innerHTML=
    '<p class="highlight">결과 — 100자 독후감</p>'+
    '<div class="result-text">'+result.text+'</div>'+
    '<div class="result-meta">'+result.summary+' (기본 '+result.basePoint+'점)</div>'+
    '<div class="advance-wrap"><button class="advance-btn" onclick="goCut5()">검토할까? &#8594;</button></div>';
  trackEvent('result_viewed',{scenarioId:sc.id,tier2:t2,basePoint:result.basePoint});
  updateStats();
}

// 컷 5: 검토 선택 (R1·R2·R3)
function goCut5(){
  var sc=getScenario();
  var c4btn=currentRow.querySelector('[data-cut="4"] .advance-wrap');if(c4btn)c4btn.style.display='none';
  setPanelImage(5,'검토');
  var panel=activatePanel(5);
  var area=document.createElement('div');area.className='choices-area';area.id='review-choices';
  area.innerHTML='<div class="choices-q">제출 전, 어떻게 검토할까?</div>';
  panel.querySelector('.panel-body').innerHTML='';
  panel.querySelector('.panel-body').appendChild(area);
  var t2cur=gameState.selectedTier2; // 'A1','A2',...
  // 각 review 잔여 비용 사전 계산 (해당 leaf = t2 + r.id)
  var costs=sc.reviews.map(function(r){return getReviewCost(t2cur+r.id);});
  var maxT=Math.max(1,Math.max.apply(null,costs.map(function(c){return c.time;})));
  var maxE=Math.max(1,Math.max.apply(null,costs.map(function(c){return c.energy;})));
  sc.reviews.forEach(function(r,i){
    var card=document.createElement('div');
    var afford=canAffordCost(costs[i]);
    card.className='choice-card'+(afford?'':' disabled');
    if(afford)card.onclick=function(){onReview(r.id);};
    var costHTML=buildCostHTML(costs[i],maxT,maxE);
    var tag=afford?'':'<span class="insufficient-tag">자원 부족</span>';
    card.innerHTML='<div class="choice-num">'+r.id+'</div><div class="choice-body"><div class="choice-text">'+r.label+tag+'</div><div class="choice-desc">'+r.desc+'</div>'+costHTML+'</div>';
    area.appendChild(card);
    setTimeout(function(){card.classList.add('visible');},i*120+150);
  });
  updateStats();
}

// 컷 6: 최종 점수 + 아이템 + 자각 + 경험치/레벨업 (Phase 4 통합)
function goCut6(){
  var sc=getScenario(),leaf=getLeafPath(),fin=sc.finals[leaf];
  // 컷5 요약
  var c5body=currentRow.querySelector('[data-cut="5"] .panel-body');
  var rvObj=sc.reviews.find(function(x){return x.id===gameState.selectedReview;});
  var supplement=sc.reviewSupplements[leaf]||'';
  c5body.innerHTML='<div class="chosen-summary"><div class="chosen-label">검토 선택</div><div class="chosen-title">'+rvObj.id+'. '+rvObj.label+'</div>'+(supplement?'<div class="chosen-way">'+supplement+'</div>':'')+'</div>';
  setPanelImage(5,'검토');
  setPanelImage(6,'최종');
  var panel=activatePanel(6);
  // Phase 5: grade 동적 산출 (사전 계산값 fin.grade 대신 실제 점수 기준)
  // item/awareness는 fin에서 그대로 사용
  var grade=getGrade(gameState.score);
  var item=fin?fin.item:null;
  var awareness=fin?fin.awareness:'';
  // cut6 panel-image에 등급+점수 큰 글자로 표시 (이미지 대신, final-grade 컬러 매칭)
  var c6img=currentRow.querySelector('[data-cut="6"] .panel-image');
  if(c6img){
    var gradeColor=({S:'#1a8c1a',A:'#1a8c1a',B:'#111',C:'#e65100',D:'#c44'})[grade]||'#222';
    c6img.innerHTML='<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;"><div style="font-size:140px;font-weight:700;color:'+gradeColor+';letter-spacing:-4px;line-height:1;">'+grade+'</div><div style="font-size:28px;color:#444;font-weight:600;">'+gameState.score+'점</div></div><span class="cut-num">CUT 6</span><span class="panel-place">최종</span>';
  }

  // === Phase 4 통합 흐름 ===
  var expGain=calculateExpGain(leaf,grade);
  var prevExp=gameState.exp.current;
  var prevLevel=gameState.exp.level;
  gameState.exp.current+=expGain;
  var didLevelUp=checkLevelUp(prevExp,gameState.exp.current);
  var newLevel=gameState.exp.level;
  // v0.5 Phase 8.7 — 부분 회복 hook 제거 (DECISIONS §10.1). RP 시스템(8.8)에서 적립으로 대체
  if(didLevelUp)applyLevelUpMeterIncrease(newLevel);
  // v0.5 Phase 8.8 — 자원토큰(RP) 적립 (DECISIONS §10.2~10.3)
  var rpAwardInfo=awardRP(grade,didLevelUp);
  // 9. scenarioRepeatCount 증가 (작업 8)
  var scid=gameState.currentScenarioId;
  gameState.scenarioRepeatCount[scid]=(gameState.scenarioRepeatCount[scid]||0)+1;

  // === 결과 화면 구성 ===
  // 등급/점수는 panel-image에 크게 표시되므로 panel-body에서는 생략
  var h='';
  if(item){
    h+='<div class="final-item"><div class="final-item-label">획득 아이템</div><div class="final-item-name">'+item+'</div></div>';
  }else{
    h+='<div class="final-item empty"><div class="final-item-label">획득 아이템</div><div class="final-item-name">없음</div></div>';
  }
  if(awareness){
    h+='<div class="awareness">'+awareness+'</div>';
  }
  // Phase 6: 이번 회기 사후 공개 (힌트 OFF 모드의 학습 피드백) — SPEC §4.2
  var t2objNow=sc.tier2[gameState.selectedTier1].find(function(x){return x.id===gameState.selectedTier2;});
  var deleg=t2objNow?t2objNow.delegation:'';
  var knl=fin?fin.knowledge:'';
  var costs=sc.resourceCosts?sc.resourceCosts[leaf]:{time:0,energy:0};
  // v0.5 Phase 8 — 역량 변화 강조 (이번 회기 delta + 누적)
  var dlgHist=gameState.competencies.delegationChoice.history;
  var knlHist=gameState.competencies.knowledge.history;
  var dlgDelta=dlgHist.length?dlgHist[dlgHist.length-1].delta:0;
  var knlDelta=knlHist.length?knlHist[knlHist.length-1].delta:0;
  var dlgTotal=gameState.competencies.delegationChoice.value;
  var knlTotal=gameState.competencies.knowledge.value;
  var fmtSign=function(v){return (v>0?'+':(v<0?'':'±'))+v;};
  var deltaColor=function(v){return v>0?'#1a8c1a':(v<0?'#c44':'#666');};
  h+='<div class="result-meta" style="margin-top:10px;padding:8px 10px;background:#f7f7f7;border-left:3px solid #111;">';
  h+='<div style="font-weight:700;font-size:12px;margin-bottom:6px;color:#111;">역량 변화 — 이번 회기</div>';
  h+='<div style="display:flex;gap:18px;flex-wrap:wrap;font-size:12px;">';
  h+='<div>위임 선택력 <b style="color:'+deltaColor(dlgDelta)+';font-size:14px;">'+fmtSign(dlgDelta)+'</b> <span style="color:#666">→ 누적 '+fmtSign(dlgTotal)+'</span> <span style="color:#888;font-size:11px;">('+(deleg||'·')+')</span></div>';
  h+='<div>도메인 지식 <b style="color:'+deltaColor(knlDelta)+';font-size:14px;">'+fmtSign(knlDelta)+'</b> <span style="color:#666">→ 누적 '+fmtSign(knlTotal)+'</span> <span style="color:#888;font-size:11px;">('+(knl||'·')+')</span></div>';
  h+='</div></div>';
  h+='<div class="result-meta" style="margin-top:6px;color:#555">이번 회기 비용 — 시간 -'+(costs.time||0)+' · 에너지 -'+(costs.energy||0)+'</div>';

  // 경험치 획득 표시 (step 기반: 현재 단계 안 진행)
  if(expGain>0){
    var thr=CONFIG.expThresholds;
    var stepCur=newLevel>=5?0:(gameState.exp.current-thr[newLevel-1]);
    var stepMax=newLevel>=5?0:(thr[newLevel]-thr[newLevel-1]);
    var expLvDisplay=newLevel>=5?'Lv.5 MAX':'Lv.'+newLevel+' '+stepCur+'/'+stepMax+' (다음 단계까지)';
    h+='<div class="result-meta" style="margin-top:6px;color:#555;font-weight:700">+'+expGain+' exp → '+expLvDisplay+'</div>';
  }

  // 레벨업 강조 표시 — 8.10b 모달과 중복으로 제거 (4/30 세션260 결정)

  // v0.5 Phase 8.7 — 자원 회복 알림 제거 (DECISIONS §10.1). 8.11에서 RP 적립 박스로 대체

  // 학기 잔여 자원 (회복 없음 — 누적 관리)
  h+='<div class="result-meta" style="margin-top:6px;color:#555">학기 잔여 — 시간 '+gameState.resources.time.current+'/'+gameState.resources.time.max+' · 에너지 '+gameState.resources.energy.current+'/'+gameState.resources.energy.max+'</div>';

  panel.querySelector('.panel-body').innerHTML=h;
  trackEvent('final_viewed',{scenarioId:sc.id,leaf:leaf,score:gameState.score,grade:grade,item:item});

  // 시나리오 완료 처리
  gameState.scenarioHistory.push({
    scenarioId:sc.id,
    tier1:gameState.selectedTier1,
    tier2:gameState.selectedTier2,
    review:gameState.selectedReview,
    leaf:leaf,
    finalScore:gameState.score,
    grade:grade,
    item:item
  });
  gameState.completed=true;

  // 이벤트 로그 (작업 9)
  trackEvent('exp_gained',{leafPath:leaf,grade:grade,baseExp:sc.expRewards?sc.expRewards[leaf]:0,gainedExp:expGain,expBefore:prevExp,expAfter:gameState.exp.current,level:newLevel});
  if(didLevelUp){
    trackEvent('level_up',{prevLevel:prevLevel,newLevel:newLevel,expAtLevelUp:gameState.exp.current,newTimeMax:gameState.resources.time.max,newEnergyMax:gameState.resources.energy.max});
  }
  trackEvent('scenario_completed',{scenarioId:sc.id,leaf:leaf,score:gameState.score,grade:grade});

  saveGame();
  updateStats();

  // 레벨업 애니메이션 (작업 7)
  if(didLevelUp){
    setTimeout(function(){
      flashLevelUpUI();
      pulseExpLevel();
    },400);
  }

  // v0.5: 컷6 결과로 충분 → 활동 리포트 거치지 않고 바로 다음 시나리오/종합 리포트
  var nw=document.getElementById('next-wrap');
  var nb=document.getElementById('next-btn');
  var clearedAfter=(gameState.clearedScenarios||[]).slice();
  if(clearedAfter.indexOf(scid)<0)clearedAfter.push(scid);
  var willBeAllDone=(clearedAfter.length>=CONFIG.scenarios.length);
  nb.textContent=willBeAllDone?'학기 종합 리포트 보기':'다음 시나리오로 →';
  nb.onclick=goNextScenario;

  // v0.5 Phase 8.10 — 모달 chain (DECISIONS §10.8 게임 루프)
  // 결과 1.4초 보여주고 → 레벨업 팝업(있으면) → 자원토큰 분배 팝업(학기 끝 아닐 때) → 다음 버튼 노출
  setTimeout(function(){
    var chain=Promise.resolve();
    if(didLevelUp){
      var prevMax=CONFIG.meterMaxByLevel[prevLevel]||{time:100,energy:100};
      var newMax={time:gameState.resources.time.max,energy:gameState.resources.energy.max};
      chain=showLevelUpModal(prevLevel,newLevel,prevMax,newMax,rpAwardInfo.fromLevelUp);
    }
    if(!willBeAllDone){
      chain=chain.then(function(){return showRPDistributionModal();});
    }
    chain.then(function(){nw.classList.add('visible');});
  },1400);
}

// =====================================================
// 10. Event Handlers
// =====================================================
function startNewGame(){
  // v0.5: 시작 화면(시나리오 선택)으로. 첫 진입 시 신규 학기 상태 생성
  if(!gameState||!gameState.clearedScenarios){
    gameState=createInitialState();
    resetSid();
    saveGame();
    trackEvent('session_started',{version:CONFIG.version});
  }
  showStartScreen();
}

function startScenario(scid){
  if(!SCENARIOS[scid])return;
  if(!gameState||!gameState.clearedScenarios){gameState=createInitialState();}
  if(gameState.clearedScenarios.indexOf(scid)>=0)return; // 1회 제한
  gameState.currentScenarioId=scid;
  gameState.currentTier=1;
  gameState.selectedTier1=null;
  gameState.selectedTier2=null;
  gameState.selectedReview=null;
  gameState.score=0;
  gameState.completed=false;
  if(typeof gameState.scenarioRepeatCount[scid]!=='number')gameState.scenarioRepeatCount[scid]=0;
  saveGame();
  currentRow=null;
  trackEvent('scenario_selected',{scenarioId:scid,clearedCount:gameState.clearedScenarios.length});
  container.innerHTML='';
  showStats();
  updateStats();
  renderCut1();
}

function goNextScenario(){
  if(!gameState)return;
  if(gameState.currentScenarioId&&gameState.clearedScenarios.indexOf(gameState.currentScenarioId)<0){
    gameState.clearedScenarios.push(gameState.currentScenarioId);
    gameState.totalScore=(gameState.totalScore||0)+gameState.score;
  }
  gameState.completed=false;
  gameState.currentScenarioId=null;
  gameState.selectedTier1=null;gameState.selectedTier2=null;gameState.selectedReview=null;gameState.score=0;
  saveGame();
  trackEvent('scenario_completed',{clearedCount:gameState.clearedScenarios.length});
  // 학기 마지막이면 종합 리포트
  if(gameState.clearedScenarios.length>=CONFIG.scenarios.length){
    showFinalReport();
  }else{
    showStartScreen();
  }
}

function continueGame(){
  gameState=loadGame();
  if(!gameState){startNewGame();return;}
  // v0.4 guard: 구버전 save에 resources 없으면 초기값 부여
  if(!gameState.resources){
    var rms=CONFIG.resourceMaxStart;
    gameState.resources={time:{current:rms.time,max:rms.time,history:[]},energy:{current:rms.energy,max:rms.energy,history:[]}};
  }
  if(!gameState.exp){gameState.exp={current:0,level:1,thresholds:CONFIG.expThresholds};}
  if(gameState.hintEnabled===undefined){gameState.hintEnabled=CONFIG.hintEnabledDefault;}
  // v0.5 guard: 학기 누적 필드
  if(!gameState.clearedScenarios)gameState.clearedScenarios=[];
  if(!gameState.scenarioRepeatCount||typeof gameState.scenarioRepeatCount!=='object'){
    var rc={};CONFIG.scenarios.forEach(function(s){rc[s]=0;});gameState.scenarioRepeatCount=rc;
  }
  // v0.5 Phase 8.8 guard: 자원토큰(RP) — 구버전 save 호환
  if(!gameState.rp||typeof gameState.rp!=='object')gameState.rp={balance:0,history:[]};
  if(typeof gameState.rp.balance!=='number')gameState.rp.balance=0;
  if(!Array.isArray(gameState.rp.history))gameState.rp.history=[];
  // 시나리오 미선택 상태면 시작 화면
  if(!gameState.currentScenarioId){showStartScreen();return;}
  trackEvent('session_continued',{version:CONFIG.version});
  container.innerHTML='';
  currentRow=null;
  showStats();
  updateStats();
  if(gameState.completed){showReport();return;}
  // 진행 단계에 따라 복원
  renderCut1();
  if(gameState.selectedTier1){
    setTimeout(function(){
      goCut2();
      // 1차 선택 표시
      setTimeout(function(){
        applyTier1ToView();
        if(gameState.selectedTier2){
          goCut3();
          setTimeout(function(){
            applyTier2ToView();
            goCut4();
            if(gameState.selectedReview){
              setTimeout(function(){
                goCut5();
                setTimeout(function(){
                  applyReviewToView();
                  goCut6();
                },200);
              },200);
            }
          },200);
        }
      },200);
    },200);
  }
}

function applyTier1ToView(){/* state already has selection — used by continueGame */}
function applyTier2ToView(){/* state already has selection */}
function applyReviewToView(){/* state already has selection */}

function fadeOutChoices(areaId,cb){
  var area=document.getElementById(areaId);
  if(!area){if(cb)cb();return;}
  var cards=area.querySelectorAll('.choice-card');
  cards.forEach(function(c,i){setTimeout(function(){c.classList.add('fade-out');},i*60);});
  setTimeout(function(){if(cb)cb();},Math.max(300,cards.length*60+200));
}

function onTier1(t1id){
  var prevTime=gameState.resources.time.current;
  var prevEnergy=gameState.resources.energy.current;
  applyTier1(t1id);
  // 단계 1 자원 소비
  consumeStage('tier1',getTier1Cost(t1id),null);
  var nowTime=gameState.resources.time.current;
  var nowEnergy=gameState.resources.energy.current;
  fadeOutChoices('tier1-choices',function(){
    goCut3();
    animateResource('time',prevTime,nowTime);
    animateResource('energy',prevEnergy,nowEnergy);
    updateStats();
  });
}

function onTier2(t2id){
  var prev=gameState.competencies.delegationChoice.value;
  var prevTime=gameState.resources.time.current;
  var prevEnergy=gameState.resources.energy.current;
  applyTier2(t2id);
  var now=gameState.competencies.delegationChoice.value;
  // 단계 2 자원 소비 (t2 = 'A1' 형식, 이미 t1 letter 포함)
  consumeStage('tier2',getTier2Cost(t2id),null);
  var nowTime=gameState.resources.time.current;
  var nowEnergy=gameState.resources.energy.current;
  fadeOutChoices('tier2-choices',function(){
    goCut4();
    animateStat('delegation',prev,now);
    animateResource('time',prevTime,nowTime);
    animateResource('energy',prevEnergy,nowEnergy);
    updateStats();
  });
}

function onReview(rid){
  var prevK=gameState.competencies.knowledge.value;
  var prevTime=gameState.resources.time.current;
  var prevEnergy=gameState.resources.energy.current;
  applyReview(rid);
  var nowK=gameState.competencies.knowledge.value;
  // 단계 3 자원 소비 (review 잔여분만 — t1+t2는 이미 차감됨)
  var leaf=getLeafPath();
  if(leaf)consumeStage('review',getReviewCost(leaf),leaf);
  var nowTime=gameState.resources.time.current;
  var nowEnergy=gameState.resources.energy.current;
  fadeOutChoices('review-choices',function(){
    goCut6();
    animateStat('knowledge',prevK,nowK);
    animateResource('time',prevTime,nowTime);
    animateResource('energy',prevEnergy,nowEnergy);
    updateStats();
    // 중앙 SCORE 펄스 — 최종 점수 강조
    var sn=document.getElementById('score-num');
    if(sn){sn.classList.add('pulsing');setTimeout(function(){sn.classList.remove('pulsing');},600);}
  });
}

function onNext(){/* placeholder — overridden in goCut6 */}

function resetGame(){
  trackEvent('session_reset',{});
  clearGame();
  resetSid();
  gameState=null;currentRow=null;
  showStartScreen();
}

// =====================================================
// 11. Report Generator (v0.3 — 두 역량 + 아이템)
// =====================================================
function showReport(){
  hideStats();
  trackEvent('final_report_viewed',{totalScore:gameState.totalScore,items:gameState.itemsCollected,history:gameState.scenarioHistory});
  var sc=getScenario();
  var last=gameState.scenarioHistory[gameState.scenarioHistory.length-1];
  var msg=sc.learningMessage;
  var h='<div class="report-overlay"><div class="report-inner"><h2>활동 리포트</h2>';
  h+='<div class="report-grid">';
