.rp-btn { background:#fff; border:1.5px solid #111; width:34px; height:34px; font-size:18px; font-weight:700; cursor:pointer; line-height:1; font-family:'Paperlogy',sans-serif; transition:all 0.15s; }
.rp-btn:hover:not(:disabled) { background:#111; color:#fff; }
.rp-btn:active:not(:disabled) { transform:scale(0.95); }
.rp-btn.charging:not(:disabled) { background:#111; color:#fff; transform:scale(0.95); box-shadow:0 0 0 3px rgba(17,17,17,0.15); }
.rp-btn:disabled { opacity:0.25; cursor:not-allowed; }
.rp-allocate { font-size:15px; font-weight:700; color:#111; min-width:30px; text-align:center; }
.rp-preview { font-size:13px; font-weight:600; color:#222; padding:12px; text-align:center; border:1px dashed #ccc; margin-bottom:14px; min-height:20px; line-height:1.5; }
