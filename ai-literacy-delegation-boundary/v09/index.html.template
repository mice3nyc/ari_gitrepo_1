.confirm-actions .confirm-destructive:hover { background:#a33; border-color:#a33; }
.semester-final { padding:24px; background:#fafafa; border:1px solid #ddd; margin:20px 0; text-align:center; }
.semester-final h2 { font-size:18px; margin-bottom:12px; }
.semester-final p { font-size:13px; color:#555; line-height:1.7; }

/* ===== pending 원 마커 (§12, 5/3 세션278) ===== */
/* 좌우 분할: 좌측 50%(음수, 중앙 쪽으로 모임) / 우측 50%(양수, 중앙에서 우측으로 뻗음) */
/* 분할 비율은 bipolar-gauge zero 위치(left:50% = 시각 중앙선)와 정렬 — SPEC 라벨 -4/+8은 점수 max(단위당 폭 비대칭)이지 시각 자리가 아니다 */
.pending-dots { display:flex; align-items:center; min-height:12px; margin:2px 0 4px; }
.pending-dots-neg { flex:0 0 50%; display:flex; flex-direction:row-reverse; justify-content:flex-start; align-items:center; gap:4px; padding-right:2px; overflow:hidden; }
.pending-dots-pos { flex:0 0 50%; display:flex; flex-direction:row; justify-content:flex-start; align-items:center; gap:4px; padding-left:2px; overflow:hidden; }
.pending-dot { width:11px; height:11px; border-radius:50%; flex-shrink:0; transition:transform 0.25s cubic-bezier(0.34,1.56,0.64,1), opacity 0.3s ease; }
.pending-dot.positive { background:#1a8c1a; box-shadow:0 1px 0 rgba(0,0,0,0.15); }
.pending-dot.negative { background:#c44; box-shadow:0 1px 0 rgba(0,0,0,0.15); }
.pending-dot.appearing { animation:dotAppear 0.35s cubic-bezier(0.34,1.56,0.64,1); }
@keyframes dotAppear {
  0% { transform:scale(0); opacity:0; }
  60% { transform:scale(1.25); opacity:1; }
  100% { transform:scale(1); opacity:1; }
}
.pending-dot.breaking { animation:dotBreak 0.35s ease forwards; }
@keyframes dotBreak {
  0% { transform:scale(1) rotate(0deg); opacity:1; }
  40% { transform:scale(1.3) rotate(15deg); opacity:0.8; }
  100% { transform:scale(0.4) rotate(-180deg); opacity:0; }
}
.pending-dot.absorbing { animation:dotAbsorb 0.6s cubic-bezier(0.55,0,0.85,0.3) forwards; }
@keyframes dotAbsorb {
  0% { transform:translateY(0) scale(1); opacity:1; }
  60% { transform:translateY(8px) scale(0.7); opacity:0.6; }
  100% { transform:translateY(18px) scale(0.1); opacity:0; }
}

/* ===== 타이틀 화면 (§11, 5/3 세션278) ===== */
.title-frame { max-width:640px; margin:0 auto; padding:40px 24px 32px; }
.title-frame h1 { font-size:26px; font-weight:700; text-align:center; margin-bottom:32px; letter-spacing:0.5px; }
.intro-text { font-size:14px; color:#555; line-height:1.9; text-align:center; margin-bottom:28px; padding:0 12px; }
.host-text { background:#fafafa; border:2px solid #111; padding:22px 24px; margin-bottom:28px; text-align:center; line-height:1.8; }
.host-text .host-q { font-size:14px; color:#444; margin-bottom:14px; }
.host-text .host-call { font-size:18px; font-weight:700; color:#111; margin-bottom:12px; letter-spacing:0.5px; }
.host-text .host-line { font-size:13px; color:#555; line-height:1.7; }
.host-text .host-line.bold { font-weight:700; color:#111; margin-top:6px; }
.tutorial-list { padding:0; margin:0 0 32px; list-style:none; counter-reset:tut; }
.tutorial-list li { position:relative; padding:14px 14px 14px 48px; margin-bottom:10px; border-left:3px solid #111; background:#fff; font-size:15px; font-weight:700; color:#111; line-height:1.75; counter-increment:tut; }
.kw-time { color:#1976d2; }
.kw-energy { color:#e65100; }
.kw-delegation { color:#6a1b9a; }
.kw-knowledge { color:#2e7d32; }
.tutorial-list li::before { content:counter(tut); position:absolute; left:14px; top:14px; width:24px; height:24px; border:1.5px solid #111; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:700; color:#111; background:#fff; }
.start-btn-large { display:block; width:100%; padding:16px; border:2px solid #111; background:#111; color:#fff; font-family:inherit; font-size:15px; font-weight:700; letter-spacing:2px; cursor:pointer; transition:background 0.15s ease; }
.start-btn-large:hover { background:#333; }
.tutorial-link { display:block; text-align:center; margin-top:14px; font-size:11px; color:#888; cursor:pointer; text-decoration:underline; background:none; border:none; font-family:inherit; }
.tutorial-link:hover { color:#444; }
/* v0.8 §11.5 — 타이틀 화면 직접 명제 정정 + 두 버튼 */
.title-frame h1 { font-size:22px; line-height:1.45; }
.title-actions { display:flex; flex-direction:column; gap:0; align-items:stretch; }

/* ===== Phase 8.10 — 모달 공통 ===== */
.modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.55); display:flex; align-items:center; justify-content:center; z-index:1000; opacity:0; pointer-events:none; transition:opacity 0.25s ease; }
.modal-overlay.visible { opacity:1; pointer-events:auto; }
.modal-overlay.hidden { display:none; }
.modal-card { background:#fff; border:2px solid #111; padding:24px 28px; width:min(440px,90vw); box-shadow:0 8px 32px rgba(0,0,0,0.22); transform:translateY(8px); transition:transform 0.25s ease; font-family:'Paperlogy',sans-serif; }
.modal-overlay.visible .modal-card { transform:translateY(0); }
.modal-title { margin:0 0 4px; font-size:18px; font-weight:700; color:#111; line-height:1.3; }
.modal-subtitle { margin:0 0 16px; font-size:14px; font-weight:700; color:#222; line-height:1.5; }

/* ===== Phase 8.10b — 레벨업 모달 ===== */
.lvup-badge { text-align:center; font-size:10px; letter-spacing:3px; color:#b58900; font-weight:700; margin-bottom:6px; }
.lvup-transition { display:flex; align-items:center; justify-content:center; gap:14px; padding:18px 0; border-top:2px solid #fff8d0; border-bottom:2px solid #fff8d0; background:#fffceb; margin:0 -28px 18px; }
.lvup-from { font-size:22px; color:#999; font-weight:600; }
.lvup-arrow { font-size:22px; color:#b58900; }
.lvup-to { font-size:36px; color:#111; font-weight:700; line-height:1; }
.lvup-effects { display:flex; flex-direction:column; gap:8px; margin-bottom:18px; }
.lvup-effect { display:flex; justify-content:space-between; align-items:center; padding:10px 14px; background:#fafafa; border:1px solid #eee; }
.lvup-effect-label { font-size:11px; color:#666; letter-spacing:0.3px; }
.lvup-effect-val { font-size:14px; color:#111; font-weight:700; }
.lvup-confirm { width:100%; padding:11px; background:#111; color:#fff; border:none; font-size:13px; font-weight:700; font-family:'Paperlogy',sans-serif; cursor:pointer; letter-spacing:1px; box-shadow:0 2px 0 #000; }
.lvup-confirm:hover { background:#444; }
.lvup-confirm:active { box-shadow:none; transform:translateY(2px); }

/* ===== Phase 8.10a — 자원토큰 분배 모달 ===== */
.rp-bal { text-align:center; padding:14px 0; border-bottom:1px solid #eee; margin-bottom:16px; }
.rp-bal-label { font-size:10px; color:#888; letter-spacing:1.5px; font-weight:600; }
.rp-bal-num { font-size:36px; font-weight:700; color:#111; line-height:1.05; }
.rp-bal-num.zero { color:#1a8c1a; }
.rp-buckets { display:flex; gap:14px; margin-bottom:14px; }
.rp-bucket { flex:1; padding:12px; border:1px solid #ddd; background:#fafafa; }
.rp-bucket-label { font-size:13px; color:#222; letter-spacing:0.5px; margin-bottom:8px; font-weight:700; }
.rp-bucket-meter { position:relative; height:22px; background:#fff; border:1px solid #ccc; overflow:hidden; margin-bottom:6px; }
