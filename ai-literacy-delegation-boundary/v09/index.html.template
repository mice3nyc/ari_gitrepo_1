// 위·도 두 축 점수 매핑 (5/3 세션278 단순화 — 선택당 ±1만, 한 시나리오 max ±3)
// ++/+/-/--/0 → 부호만 보고 +1/0/-1로 매핑. 학생이 원 1·2·3개로 직관적으로 잡힘.
function getAxisDelta(sign){
  if(!sign||sign==='0')return 0;
  if(sign==='+'||sign==='++')return 1;
  if(sign==='-'||sign==='--')return -1;
  return 0;
}
var GRADE_LABEL={S:'S',A:'A',B:'B',C:'C',D:'D'};

