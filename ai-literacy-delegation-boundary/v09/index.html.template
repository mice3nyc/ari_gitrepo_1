.rp-preview.empty { color:#999; }
.rp-confirm { width:100%; padding:11px; background:#111; color:#fff; border:none; font-size:13px; font-weight:700; font-family:'Paperlogy',sans-serif; cursor:pointer; letter-spacing:1px; transition:all 0.2s; box-shadow:0 2px 0 #000; }
.rp-confirm:hover:not(:disabled) { background:#444; }
.rp-confirm:active:not(:disabled) { box-shadow:none; transform:translateY(2px); }
.rp-confirm:disabled { background:#bbb; color:#fff; cursor:not-allowed; box-shadow:none; }
/* ===== 역량 카드 인벤토리 (§7.5) ===== */
.inv-tab { position:fixed; top:50%; right:-6px; transform:translateY(-50%); z-index:200; padding:18px 22px 18px 18px; border:2px solid #111; background:#fff; color:#111; font-family:inherit; cursor:pointer; box-shadow:-3px 3px 0 #111; transition:background 0.2s, transform 0.15s; border-radius:14px; min-width:108px; text-align:left; }
.inv-tab:hover { background:#f8f8f8; transform:translateY(-50%) translateX(-4px); }
.inv-tab-name { display:block; font-size:15px; font-weight:700; letter-spacing:1.5px; line-height:1.2; margin-bottom:4px; }
.inv-tab-desc { display:block; font-size:11px; color:#666; font-weight:500; letter-spacing:0.5px; line-height:1.3; }
.inv-tab-badge { position:absolute; top:8px; right:8px; width:10px; height:10px; background:#c44; border-radius:50%; box-shadow:0 0 0 2px #fff; }
.inv-tab-badge.hidden { display:none; }
.inv-panel-backdrop { position:fixed; inset:0; background:rgba(0,0,0,0.25); z-index:300; opacity:0; pointer-events:none; transition:opacity 0.3s ease; }
.inv-panel-backdrop.open { opacity:1; pointer-events:auto; }
.inv-panel { position:fixed; top:0; right:0; height:100vh; width:320px; max-width:90vw; background:#fff; border-left:2px solid #111; box-shadow:-4px 0 0 #111; z-index:310; transform:translateX(100%); transition:transform 0.35s cubic-bezier(0.34,1.2,0.64,1); display:flex; flex-direction:column; }
.inv-panel.open { transform:translateX(0); }
.inv-panel-header { display:flex; align-items:center; justify-content:space-between; padding:16px 20px; border-bottom:2px solid #111; }
.inv-panel-title { font-size:16px; font-weight:700; letter-spacing:1px; }
.inv-panel-close { background:none; border:1.5px solid #111; width:28px; height:28px; font-size:16px; font-weight:700; cursor:pointer; line-height:1; }
.inv-panel-close:hover { background:#f0f0f0; }
.inv-panel-body { flex:1; overflow-y:auto; padding:16px 20px; }
.inv-empty { font-size:13px; color:#888; text-align:center; padding:40px 12px; line-height:1.7; }
/* 5/3 — inv-card 재배치: 좌측 색띠(카드색+카운트, 흰 글씨) + 우측 본문(라벨 큰 글씨) */
.inv-card { display:flex; flex-direction:column; margin-bottom:8px; border:1.5px solid #111; background:#fff; box-shadow:0 2px 0 #111; cursor:pointer; transition:transform 0.15s, box-shadow 0.15s; border-radius:8px; overflow:hidden; }
.inv-card:hover { transform:translate(-1px,-1px); box-shadow:1px 3px 0 #111; }
.inv-card-row { display:flex; align-items:stretch; gap:0; min-height:54px; }
.inv-card-count { font-size:22px; font-weight:800; color:#fff; background:#888; flex:0 0 50px; display:flex; align-items:center; justify-content:center; line-height:1; letter-spacing:0.3px; }
.inv-card-body { flex:1; display:flex; align-items:center; padding:12px 14px; }
.inv-card-label { font-size:18px; font-weight:700; color:#111; line-height:1.25; word-break:keep-all; }
/* 5/3 — expand 시각 신호 (chevron). 닫힘 ⌄ → 열림 180deg 회전 */
.inv-card-chevron { flex:0 0 auto; display:flex; align-items:center; justify-content:center; padding:0 14px 0 4px; font-size:16px; color:#888; line-height:1; transition:transform 0.25s ease; transform-origin:center; }
.inv-card.expanded .inv-card-chevron { transform:rotate(180deg); }
.inv-card-detail { font-size:11px; color:#666; padding:8px 14px 10px; border-top:1px dashed #ddd; line-height:1.6; display:none; background:#fafafa; }
.inv-card.expanded .inv-card-detail { display:block; }
/* 5/3 — expand 영역 카드 의미 박스 (좌측 색띠 + 본문) */
.inv-card-meaning { display:none; padding:12px 14px; border-top:1px dashed #ddd; border-left:4px solid #888; background:#fff; }
.inv-card.expanded .inv-card-meaning { display:block; }
.inv-card-meaning-label { font-size:14px; font-weight:800; color:#111; margin-bottom:4px; }
.inv-card-meaning-def { font-size:12px; font-weight:600; color:#333; margin-bottom:8px; line-height:1.5; word-break:keep-all; }
.inv-card-meaning-desc { font-size:12px; color:#555; line-height:1.7; word-break:keep-all; white-space:pre-line; }
.inv-card-detail-title { font-size:10px; font-weight:700; color:#888; letter-spacing:1px; text-transform:uppercase; margin-bottom:6px; }
/* ===== reward 팝업 — 단건 컨펌 (§7.6, 5/3 세션278) ===== */
.card-reward-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.3); z-index:400; display:flex; align-items:center; justify-content:center; pointer-events:auto; }
.card-reward-overlay.hidden { display:none; }
/* 5/3 — Pop In! 애니메이션 (fadein 폐기): scale + rotate 오버슛 + box-shadow pulse
   5/3 정정 — 카드 N장 동시 펼침 (5점 별/W 패턴 좌표). 각 카드마다 다른 (top,left) %로 배치. */
.card-reward-card { position:fixed; width:220px; padding:18px 18px 14px 22px; border:2px solid #111; background:#fff; box-shadow:0 4px 0 #111; border-radius:12px; opacity:0; z-index:405; border-left-width:22px;
  /* 기본: 중앙 (1장 분기 / fallback). top/left는 JS에서 인라인으로 덮어씀
     5/3 정정 — 폭 280→220, 좌표 압축에 맞춰 카드도 작게 */
  top:50%; left:50%; transform:translate(-50%,-50%) scale(0.3) rotate(-5deg);
}
.card-reward-card.appear { animation:cardPopIn 0.5s cubic-bezier(0.34,1.56,0.64,1) forwards, cardGlow 0.6s ease 0.15s; }
@keyframes cardPopIn {
  0%   { opacity:0; transform:translate(-50%,-50%) scale(0.3) rotate(-5deg); }
  60%  { opacity:1; transform:translate(-50%,-50%) scale(1.15) rotate(2deg); }
  80%  { transform:translate(-50%,-50%) scale(0.96) rotate(-1deg); }
  100% { opacity:1; transform:translate(-50%,-50%) scale(1) rotate(0deg); }
}
@keyframes cardGlow {
  0%   { box-shadow:0 4px 0 #111, 0 0 0 0 rgba(255,220,80,0); }
  35%  { box-shadow:0 4px 0 #111, 0 0 36px 14px rgba(255,220,80,0.55); }
  100% { box-shadow:0 4px 0 #111, 0 0 0 0 rgba(255,220,80,0); }
}
.card-reward-card.travel { opacity:0; transition:opacity 0.35s ease-in, transform 0.35s cubic-bezier(0.55,0,0.85,0.3); }
.card-reward-tag { font-size:9px; color:#888; letter-spacing:1.4px; font-weight:700; margin-bottom:5px; }
.card-reward-label { font-size:19px; font-weight:700; color:#111; margin-bottom:8px; letter-spacing:0.4px; }
.card-reward-divider { height:1px; background:#ddd; margin:6px 0 8px; }
.card-reward-note { font-size:11px; color:#555; line-height:1.65; margin-bottom:12px; }
.card-reward-confirm { display:block; width:100%; padding:8px 12px; border:1.5px solid #111; background:#111; color:#fff; font-family:inherit; font-size:12px; font-weight:700; letter-spacing:1px; cursor:pointer; transition:background 0.15s ease; }
.card-reward-confirm:hover { background:#333; }
.card-reward-confirm:disabled { background:#888; border-color:#888; cursor:default; }
/* 성장 카드 (회복력/도전력) 전용 스타일 */
.card-reward-card.growth-card { border:2.5px dashed #546e7a; border-left-width:2.5px; background:#f8f9fa; box-shadow:0 4px 16px rgba(0,0,0,0.12); }
.growth-symbol { font-size:32px; text-align:center; margin-bottom:6px; line-height:1; color:#546e7a; }
/* 회복력 중앙 오버레이 */
.recovery-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:410; display:flex; align-items:center; justify-content:center; animation:fadeIn 0.3s ease; }
.recovery-overlay.hidden { display:none; }
.recovery-card { width:300px; padding:28px 24px; border:2.5px dashed #546e7a; background:#f8f9fa; border-radius:16px; text-align:center; box-shadow:0 8px 32px rgba(0,0,0,0.2); animation:recoveryPopIn 0.5s cubic-bezier(0.34,1.56,0.64,1) forwards; opacity:0; }
@keyframes recoveryPopIn {
  0%   { opacity:0; transform:scale(0.3); }
  60%  { opacity:1; transform:scale(1.08); }
  100% { opacity:1; transform:scale(1); }
}
.recovery-card .growth-symbol { font-size:48px; margin-bottom:12px; }
.recovery-card-title { font-size:20px; font-weight:700; color:#546e7a; margin-bottom:6px; }
.recovery-card-desc { font-size:13px; color:#666; line-height:1.5; margin-bottom:20px; }
.recovery-card-btn { display:block; width:100%; padding:12px; margin-bottom:8px; font-family:inherit; font-size:14px; font-weight:700; border-radius:8px; cursor:pointer; transition:all 0.15s; }
.recovery-card-btn.primary { background:#546e7a; color:#fff; border:2px solid #546e7a; }
.recovery-card-btn.primary:hover { background:#455a64; }
.recovery-card-btn.secondary { background:transparent; color:#888; border:1.5px solid #ccc; font-weight:600; }
.recovery-card-btn.secondary:hover { border-color:#999; color:#666; }
.no-card-notice { margin-top:10px; padding:8px 12px; background:#f7f7f7; border-left:3px solid #bbb; font-size:12px; color:#666; }
/* ===== GAME OVER 모달 (5/3 정정 — 자원 부족) ===== */
.gameover-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.65); z-index:1100; display:flex; align-items:center; justify-content:center; opacity:0; pointer-events:none; transition:opacity 0.25s ease; }
.gameover-overlay.visible { opacity:1; pointer-events:auto; }
.gameover-overlay.hidden { display:none; }
.gameover-card { background:#fff; border:2px solid #111; padding:24px 28px; width:min(440px,90vw); box-shadow:0 8px 32px rgba(0,0,0,0.3); transform:translateY(8px); transition:transform 0.25s ease; font-family:'Paperlogy',sans-serif; text-align:center; }
.gameover-overlay.visible .gameover-card { transform:translateY(0); }
.gameover-title { font-size:26px; font-weight:800; color:#111; letter-spacing:2px; margin-bottom:10px; }
.gameover-body { font-size:13px; color:#333; line-height:1.6; margin-bottom:14px; }
.gameover-resources { display:flex; justify-content:center; gap:14px; margin-bottom:18px; padding:10px; background:#f7f7f7; border:1px dashed #bbb; }
.gameover-resource { display:flex; flex-direction:column; align-items:center; }
.gameover-resource-label { font-size:10px; color:#888; letter-spacing:1px; font-weight:700; }
.gameover-resource-num { font-size:20px; font-weight:800; color:#c44; }
.gameover-actions { display:flex; gap:10px; }
.gameover-actions button { flex:1; padding:12px 16px; font-family:inherit; font-size:13px; font-weight:700; cursor:pointer; transition:all 0.15s ease; border:2px solid #111; }
.gameover-actions .gameover-report { background:#111; color:#fff; }
.gameover-actions .gameover-report:hover { background:#333; }
.gameover-actions .gameover-restart { background:#fff; color:#111; }
.gameover-actions .gameover-restart:hover { background:#f3f3f3; }
</style>
</head>
<body>
<!-- 좌/우 패널 (sticky) — 좌:자원 / 우:역량+점수+진행 -->
<div class="panel-row" id="panel-row">
  <!-- 좌측: 자원 게이지 (시간/에너지) -->
  <div class="resource-bar" id="resource-bar">
    <div class="panel-title">자원</div>
    <div class="resource-item" id="res-time"><div class="resource-change-indicator" id="rdelta-time"></div><div class="resource-header"><span class="resource-name">시간</span><span class="resource-num" id="rnum-time">120</span></div><div class="resource-gauge"><div class="resource-gauge-fill" id="rgauge-time" style="width:100%"></div></div></div>
    <div class="resource-item" id="res-energy"><div class="resource-change-indicator" id="rdelta-energy"></div><div class="resource-header"><span class="resource-name">에너지</span><span class="resource-num" id="rnum-energy">70</span></div><div class="resource-gauge"><div class="resource-gauge-fill" id="rgauge-energy" style="width:100%"></div></div></div>
  </div>
  <!-- 중앙: LV + SCORE + XP -->
  <div class="score-display" id="score-display">
    <div class="score-display-row">
      <div class="score-block">
        <span class="display-label">LV</span>
        <span class="display-num" id="lv-num">1</span>
      </div>
      <div class="score-vsep"></div>
      <div class="score-block">
        <span class="display-label">SCORE</span>
        <span class="display-num" id="score-num">0</span>
      </div>
    </div>
    <!-- XP 진행 바 (LV/SCORE 아래) -->
    <div class="exp-display" id="exp-display">
      <div class="exp-header">
        <span class="exp-level" id="exp-level">XP</span>
        <span class="exp-num" id="exp-num">0/20</span>
      </div>
      <div class="exp-bar"><div class="exp-bar-fill" id="exp-bar-fill" style="width:0%"></div></div>
    </div>
  </div>
  <!-- 우측: 역량(양방향 바) + 진행 -->
  <div class="stats-bar" id="stats-bar">
    <div class="panel-title">역량</div>
    <div class="stat" id="stat-delegation">
      <div class="stat-change-indicator" id="delta-delegation"></div>
      <div class="stat-header"><span class="stat-name">판단하는 힘</span><span class="stat-num" id="num-delegation">0</span></div>
      <div class="pending-dots" id="pending-dots-delegation" aria-label="이번 시나리오 판단하는 힘 변화"><div class="pending-dots-neg" id="pending-dots-delegation-neg"></div><div class="pending-dots-pos" id="pending-dots-delegation-pos"></div></div>
      <div class="bipolar-gauge"><div class="bipolar-zero"></div><div class="bipolar-fill" id="gauge-delegation"></div></div>
      <div class="bipolar-labels"><span>-10</span><span>+20</span></div>
    </div>
    <div class="stat" id="stat-knowledge">
      <div class="stat-change-indicator" id="delta-knowledge"></div>
      <div class="stat-header"><span class="stat-name" id="stat-name-knowledge">아는것의 힘</span><span class="stat-num" id="num-knowledge">0</span></div>
      <div class="pending-dots" id="pending-dots-knowledge" aria-label="이번 시나리오 아는것의 힘 변화"><div class="pending-dots-neg" id="pending-dots-knowledge-neg"></div><div class="pending-dots-pos" id="pending-dots-knowledge-pos"></div></div>
      <div class="bipolar-gauge"><div class="bipolar-zero"></div><div class="bipolar-fill" id="gauge-knowledge"></div></div>
      <div class="bipolar-labels"><span>-10</span><span>+20</span></div>
    </div>
  </div>
</div>
<div class="container" id="main-container"></div>
<!-- 역량 카드 인벤토리 탭 (우측 가장자리 고정 / texts.yaml inject — 초기값은 fallback) -->
<button class="inv-tab" id="inv-tab" onclick="toggleInventory()" aria-label="역량 카드 인벤토리 열기"><span class="inv-tab-name" id="inv-tab-name">역량 카드</span><span class="inv-tab-desc" id="inv-tab-desc">모은 카드 보기</span><span class="inv-tab-badge hidden" id="inv-tab-badge"></span></button>
<div class="inv-panel-backdrop" id="inv-panel-backdrop" onclick="toggleInventory(false)"></div>
<aside class="inv-panel" id="inv-panel" aria-hidden="true">
  <div class="inv-panel-header">
    <span class="inv-panel-title" id="inv-panel-title">역량 카드</span>
    <button class="inv-panel-close" onclick="toggleInventory(false)" aria-label="닫기">×</button>
  </div>
  <div class="inv-panel-body" id="inv-list">
    <div class="inv-empty">아직 획득한 카드가 없어요.<br>시나리오 끝에 카드를 받을 수 있습니다.</div>
  </div>
</aside>
<div class="card-reward-overlay hidden" id="card-reward-overlay"></div>
<div class="recovery-overlay hidden" id="recovery-overlay"></div>
<button class="debug-toggle" onclick="toggleDebug()">DEBUG</button>
<div class="debug-panel" id="debug-panel"></div>
<div class="version">v0.8</div>

<!-- Phase 8.10b — 레벨업 이벤트 팝업 (DECISIONS §10.11) -->
<div id="levelup-modal" class="modal-overlay hidden">
  <div class="modal-card">
    <div class="lvup-badge">LEVEL UP</div>
    <div class="lvup-transition">
      <span class="lvup-from" id="lvup-from">Lv.1</span>
      <span class="lvup-arrow">→</span>
      <span class="lvup-to" id="lvup-to">Lv.2</span>
    </div>
    <div class="lvup-effects">
      <div class="lvup-effect">
        <span class="lvup-effect-label">자원 메터 max 증가</span>
        <span class="lvup-effect-val" id="lvup-meter-delta">시간 +10 / 에너지 +10</span>
      </div>
      <div class="lvup-effect">
        <span class="lvup-effect-label">자원토큰 보너스</span>
        <span class="lvup-effect-val" id="lvup-token-bonus">+20</span>
      </div>
    </div>
    <button id="lvup-confirm" class="lvup-confirm" type="button">확인 →</button>
  </div>
</div>

<!-- GAME OVER 모달 (5/3 정정 — 자원 부족 시 / texts.yaml inject) -->
<div id="gameover-modal" class="gameover-overlay hidden">
  <div class="gameover-card">
    <div class="gameover-title" id="gameover-title">GAME OVER</div>
    <div class="gameover-body" id="gameover-body">자원이 부족해요.<br>시간과 에너지가 모자라 더 이상 선택할 수 없습니다.</div>
    <div class="gameover-resources">
      <div class="gameover-resource"><span class="gameover-resource-label" id="gameover-time-label">시간</span><span class="gameover-resource-num" id="gameover-time">0</span></div>
      <div class="gameover-resource"><span class="gameover-resource-label" id="gameover-energy-label">에너지</span><span class="gameover-resource-num" id="gameover-energy">0</span></div>
    </div>
    <div class="gameover-actions">
      <button class="gameover-report" id="gameover-btn-report" onclick="gameOverShowReport()">리포트 보기</button>
      <button class="gameover-restart" id="gameover-btn-restart" onclick="gameOverRestart()">학기 처음부터</button>
    </div>
  </div>
</div>

<!-- 학기 처음부터 확인 모달 (5/3 세션278) -->
<div id="reset-confirm-modal" class="modal-overlay hidden">
  <div class="modal-card">
    <div class="modal-title">학기를 처음부터 시작할까요?</div>
    <div class="modal-subtitle">지금까지 진행한 학기가 모두 사라지고 새 학생으로 다시 시작합니다.</div>
    <div class="confirm-actions">
      <button class="confirm-cancel" onclick="closeResetConfirm()">계속하기</button>
      <button class="confirm-destructive" onclick="confirmResetDo()">다시 시작</button>
    </div>
  </div>
</div>

<!-- Phase 8.10a — 자원토큰 분배 팝업 (DECISIONS §10.5) -->
<div id="rp-modal" class="modal-overlay hidden">
  <div class="modal-card">
    <div class="modal-title">자원토큰 분배</div>
    <div class="modal-subtitle">받은 토큰을 시간과 에너지에 나눠 담으세요. 남은 토큰이 0이 되면 다음 시나리오로 넘어갑니다.</div>
    <div class="rp-bal">
      <div class="rp-bal-label">남은 자원토큰</div>
      <div class="rp-bal-num" id="rp-bal-num">0</div>
    </div>
    <div class="rp-buckets">
      <div class="rp-bucket" data-axis="time">
        <div class="rp-bucket-label">시간</div>
        <div class="rp-bucket-meter">
          <div class="rp-bucket-fill" id="rp-bucket-time-fill" style="width:0%"></div>
          <div class="rp-bucket-overlay" id="rp-bucket-time-overlay" style="width:0%; left:0%"></div>
        </div>
        <div class="rp-bucket-num" id="rp-bucket-time-num">0/120</div>
        <div class="rp-bucket-controls">
          <button class="rp-btn rp-minus" data-axis="time" type="button">−</button>
          <span class="rp-allocate" id="rp-allocate-time">+0</span>
          <button class="rp-btn rp-plus" data-axis="time" type="button">+</button>
        </div>
      </div>
      <div class="rp-bucket" data-axis="energy">
        <div class="rp-bucket-label">에너지</div>
        <div class="rp-bucket-meter">
          <div class="rp-bucket-fill" id="rp-bucket-energy-fill" style="width:0%"></div>
          <div class="rp-bucket-overlay" id="rp-bucket-energy-overlay" style="width:0%; left:0%"></div>
        </div>
        <div class="rp-bucket-num" id="rp-bucket-energy-num">0/70</div>
        <div class="rp-bucket-controls">
          <button class="rp-btn rp-minus" data-axis="energy" type="button">−</button>
          <span class="rp-allocate" id="rp-allocate-energy">+0</span>
          <button class="rp-btn rp-plus" data-axis="energy" type="button">+</button>
        </div>
      </div>
    </div>
    <div class="rp-preview empty" id="rp-preview">토큰을 시간/에너지에 분배하세요</div>
    <button id="rp-confirm" class="rp-confirm" type="button" disabled>분배 완료 →</button>
  </div>
</div>

<script>
// =====================================================
// 3. Config
// =====================================================
var CONFIG={
  storageKey:'ai-literacy-delegation-boundary-v09',
  eventLogKey:'ai-literacy-delegation-boundary-v08-events',
  sessionIdKey:'ai-literacy-v08-session-id',
  version:'v0.8',
  scenarios:['selfintro','groupwork','eorinwangja','career','studyplan'],
  pointThresholds:{S:95,A:85,B:75,C:60,D:0},
  minResourceCost:1,
  cardBoost:20,
  detectedIssueBoost:10,
  // v0.4 신규 (SPEC §12) — Phase 3 이후 사용
  resourceMaxStart:{time:120,energy:70},
  // v0.5 — 비용 multiplier (데이터 보존 + 튜닝 조정용). 0.6 = 적정 선택 시 1.7~3 시나리오 버팀
